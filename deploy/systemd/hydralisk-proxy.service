[Unit]
Description=Hydralisk GPT-OSS 20B proxy
After=network-online.target vllm-gpt-oss-20b.service
Wants=network-online.target vllm-gpt-oss-20b.service

[Service]
Type=simple
User=hydralisk
Group=hydralisk
WorkingDirectory=/opt/hydralisk
EnvironmentFile=/etc/hydralisk/hydralisk.env
ExecStart=/opt/hydralisk/.venv/bin/uvicorn hydralisk.serve.proxy:app --host 127.0.0.1 --port 8080 --proxy-headers
Restart=always
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/hydralisk

[Install]
WantedBy=multi-user.target
